# === RiRi AI — Local Environment Variables ===
# Copy this file to .env.local before starting development.
# IMPORTANT: Never commit .env.local to version control.

# --- Supabase (Cloud Managed) ---
# Get these from Supabase Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI APIs ---
# OpenRouter: Primary gateway for LLMs (Gemini, Claude, etc.)
OPENROUTER_API_KEY=sk-or-v1-....

# Jina AI: For embeddings (used in scriptwriter RAG)
JINA_API_KEY=jina_....

# Mem0: User-specific memory for AI chat
MEM0_API_KEY=your-mem0-key

# --- External Tools ---
# RapidAPI: Instagram data scraping (instagram-scraper-20251)
RAPIDAPI_KEY=your-rapidapi-key

# Resend: Email delivery
RESEND_API_KEY=re_....

# --- Backend Specific ---
NODE_ENV=development
VERCEL_URL=localhost:3000
